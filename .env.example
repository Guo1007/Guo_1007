# ========== AI 配置 ==========
# 通义千问 API Key（AI 聊天功能必需）
CHAT_AI_API_KEY=sk-your-api-key-here
EMBEDDING_KEY=sk-your-embedding-key-here

# ========== 阿里云 OSS ==========
# 图片上传必需
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY=your-access-key
OSS_SECRET_KEY=your-secret-key
OSS_BUCKET=your-bucket-name
OSS_URL=https://your-bucket.oss-cn-beijing.aliyuncs.com

# ========== MySQL ==========
MYSQL_ROOT_PASSWORD=root

# ========== 邮件（验证码功能）==========
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-mail-auth-code

# ========== RocketMQ ==========
ROCKETMQ_NAME_SERVER=rocketmq-namesrv:9876
